// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique // Identyfikator AD
  fullName  String
  role      String // Administrator, Minister, Logistyk, Magazynier
  password  String // W produkcji użyjemy bcrypt do hashowania
  unit      String? // Jednostka wojskowa
  createdAt DateTime @default(now())
}

model Resource {
  id               Int      @id @default(autoincrement())
  natoCode         String   @unique // Kod NATO
  name             String
  warehouse        String // Lokalizacja
  quantity         Int // Stan aktualny
  warningThreshold Int // Próg ostrzegawczy
  unit             String   @default("szt.")
  updatedAt        DateTime @updatedAt
}

model Order {
  id           Int      @id @default(autoincrement())
  orderDate    DateTime @default(now())
  resourceName String
  quantity     Int
  status       String // W TRANSPORCIE, OCZEKUJE, ODEBRANO
  notes        String?
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  user      String // Kto wykonał akcję
  action    String // Opis akcji
  ip        String? // Adres IP operatora
  timestamp DateTime @default(now())
}
