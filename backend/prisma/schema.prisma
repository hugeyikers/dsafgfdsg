// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  fullName String
  role     Role     @default(USER)
  password String
  createdAt DateTime @default(now())
  assignedTasks KanbanItem[]
}

model KanbanColumn {
  id        Int          @id @default(autoincrement())
  title     String
  order     Int
  limit     Int          @default(0) // 0 means no limit
  items     KanbanItem[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model KanbanItem {
  id        Int          @id @default(autoincrement())
  content   String
  order     Int
  columnId  Int
  column    KanbanColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignedToId Int?
  assignedTo User?       @relation(fields: [assignedToId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

enum Role {
  ADMINISTRATOR
  USER
}
