// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id            Int           @id @default(autoincrement())
  email         String        @unique
  fullName      String
  role          Role          @default(USER)
  password      String
  createdAt     DateTime      @default(now())
  assignedTasks KanbanItem[]
  limit         Int?
}

model KanbanColumn {
  id            Int          @id @default(autoincrement())
  title         String
  order         Int
  limit         Int          @default(0) // 0 means no limit
  items         KanbanItem[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  color         String?
}

model KanbanRow {
  id            Int          @id @default(autoincrement())
  title         String
  order         Int
  limit         Int          @default(0) // 0 means no limit
  items         KanbanItem[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  color         String?
}

model KanbanItem {
  id            Int          @id @default(autoincrement())
  title         String
  content       String
  order         Int
  columnId      Int
  column        KanbanColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  rowId         Int?
  row           KanbanRow?   @relation(fields: [rowId], references: [id], onDelete: Cascade)
  assignedUsers User[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  color         String?
  subtasks      KanbanItemSubTask[] 
}

model KanbanItemSubTask {
  id            Int         @id @default(autoincrement())
  itemId        Int
  item          KanbanItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  title         String
  content       String
  createdAt     DateTime    @default(now())
  isDone        Boolean     @default(false)
}

enum Role {
  ADMINISTRATOR
  USER
}
